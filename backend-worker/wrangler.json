{
  "name": "curriculum-backend",
  "main": "src/index.ts",
  "compatibility_date": "2024-04-03",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "d1_databases": [
    {
      "binding": "curriculum_db",
      "database_name": "curriculum-db",
      "database_id": "3a696de6-d975-45cc-8a2b-c59a290bfedc"
    }
  ],
  "r2_buckets": [
    {
      "binding": "BUCKET",
      "bucket_name": "curriculum-files"
    }
  ],
  "browser": {
    "binding": "BROWSER"
  },
  "queues": {
    "producers": [
      {
        "binding": "PUBLISH_QUEUE",
        "queue": "publish-queue"
      }
    ],
    "consumers": [
      {
        "queue": "publish-queue",
        "max_batch_size": 1
      }
    ]
  },
  "observability": {
    "enabled": true
  },
  "vars": {
    "CORS_ALLOWED_ORIGINS": "http://localhost:3000",
    "ENVIRONMENT": "development"
  }
}